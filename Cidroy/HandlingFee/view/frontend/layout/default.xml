<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!-- Mini-cart sidebar: inject under subtotal.container, after the subtotal row -->
        <referenceBlock name="minicart">
            <arguments>
                <argument name="jsLayout" xsi:type="array">
                    <item name="components" xsi:type="array">
                        <item name="minicart_content" xsi:type="array">
                            <item name="children" xsi:type="array">
                                <item name="subtotal.container" xsi:type="array">
                                    <item name="children" xsi:type="array">
                                        <item name="handling_fee" xsi:type="array">
                                            <item name="component" xsi:type="string">Cidroy_HandlingFee/js/view/minicart/handling-fee</item>
                                            <item name="sortOrder" xsi:type="string">20</item>
                                            <item name="config" xsi:type="array">
                                                <item name="template" xsi:type="string">Cidroy_HandlingFee/minicart/totals/handling-fee</item>
                                            </item>
                                        </item>
                                    </item>
                                </item>
                            </item>
                        </item>
                    </item>
                </argument>
            </arguments>
        </referenceBlock>
    </body>
</page>
