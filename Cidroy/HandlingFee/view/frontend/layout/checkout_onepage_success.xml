<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="order.info.totals">
            <block class="Cidroy\HandlingFee\Block\Order\Totals\HandlingFee"
                   name="cidroy.handling_fee.success.totals"/>
        </referenceBlock>

        <referenceContainer name="order.success.additional.info">
            <block class="Cidroy\HandlingFee\Block\Checkout\Success\OrderSummary"
                   name="cidroy.handling_fee.success.summary"
                   template="Cidroy_HandlingFee::checkout/success/order-summary.phtml"
                   cacheable="false"/>
        </referenceContainer>
    </body>
</page>
