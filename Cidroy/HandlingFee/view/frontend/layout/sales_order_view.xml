<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!--
            order_totals (Magento\Sales\Block\Order\Totals) is defined in
            Magento_Sales::sales_order_view.xml. Our block calls initTotals()
            and inserts the fee line before grand_total.
        -->
        <referenceBlock name="order_totals">
            <block class="Cidroy\HandlingFee\Block\Order\Totals\HandlingFee"
                   name="cidroy.handling_fee.order.totals"/>
        </referenceBlock>
    </body>
</page>
